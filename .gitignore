# ============================================================
# StorySphere .gitignore
# ============================================================

# ========== Claude Code ==========
.claude/settings.local.json
.claude/skills/
.playwright-cli/

# ========== Environment & Secrets ==========
.env
.env.local
.env.*.local
*.pem
*.key
credentials*

# ========== Python ==========
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST

# ========== Virtual Environments ==========
.venv/
venv/
env/
ENV/

# ========== Testing & Coverage ==========
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ========== Type Checking ==========
.mypy_cache/
.dmypy.json
dmypy.json

# ========== Linting ==========
.ruff_cache/

# ========== IDE ==========
.vscode/
.idea/
*.swp
*.swo

# ========== OS ==========
.DS_Store
Thumbs.db

# ========== Database ==========
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ========== Logs ==========
*.log
logs/
\# Optional log file path

# ========== Experiments (local only, never commit) ==========
experiments/

# ========== Data & Uploads ==========
var/uploads/
var/processed/
var/knowledge_graph.json
var/qdrant_local/

# Backend runtime data (SQLite stores, local Qdrant) — never commit
backend/var/

# ========== uv ==========
# uv.lock    # Do NOT ignore - commit lock file for reproducibility
