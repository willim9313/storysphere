# ============================================================
# StorySphere - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ========== LLM Providers ==========
# Set PRIMARY_LLM_PROVIDER to whichever provider you have an API key for.
# Only that provider's key is required; others can be left empty.
PRIMARY_LLM_PROVIDER=gemini                      # gemini | openai | anthropic | local

GEMINI_API_KEY=your_gemini_api_key_here          # Required if PRIMARY_LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash                    # Gemini model name
OPENAI_API_KEY=your_openai_api_key_here          # Required if PRIMARY_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini                         # OpenAI model name
ANTHROPIC_API_KEY=your_anthropic_api_key_here    # Required if PRIMARY_LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-3-5-haiku-latest          # Anthropic model name

# Local LLM — OpenAI-compatible endpoint (no API key required)
# Supported backends: llama.cpp server, Ollama (/v1 path), LM Studio
# Set LOCAL_LLM_MODEL to a non-empty value to enable.
# Fallback chain: Gemini → OpenAI → Anthropic → Local
# Pure-local mode: leave all cloud keys empty and set LOCAL_LLM_MODEL only.
#
# llama.cpp server example:
#   llama-server -m qwen2.5-3b.gguf --port 8080
#   LOCAL_LLM_BASE_URL=http://localhost:8080/v1
#
# Ollama example:
#   ollama serve  (default port 11434)
#   LOCAL_LLM_BASE_URL=http://localhost:11434/v1
#
LOCAL_LLM_BASE_URL=http://localhost:11434/v1     # Local server base URL
LOCAL_LLM_MODEL=                                 # e.g. qwen2.5:3b, llama3.2, phi3.5

# ========== Database ==========
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./storysphere.db

# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/storysphere

# ========== Vector Database (Qdrant) ==========
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                                  # Leave empty for local Qdrant
QDRANT_COLLECTION_PREFIX=storysphere_book         # Per-book collection prefix

# ========== Deployment Mode ==========
# lightweight (default): zero-config startup, Qdrant stores data locally at QDRANT_LOCAL_PATH.
#   Required: nothing beyond Python environment.
#   KG: always networkx (Neo4j not available in this mode).
#   Note: first run downloads embedding model (~80MB from HuggingFace, one-time).
#
# standard: production-grade, requires external Qdrant service.
#   Required: Qdrant service running at QDRANT_URL before startup.
#   On startup failure: explicit error, no silent fallback.
#   Switching modes requires data migration (see I-002 Migration CLI).
DEPLOY_MODE=lightweight
QDRANT_LOCAL_PATH=./data/qdrant_local

# ========== Knowledge Graph ==========
KG_MODE=networkx                                 # networkx | neo4j
KG_PERSISTENCE_PATH=./data/knowledge_graph.json  # NetworkX JSON persistence path
KG_AUTO_SWITCH_THRESHOLD=10000                   # Entity count above which Neo4j is recommended

# Neo4j (only used when KG_MODE=neo4j)
# Requires Docker: docker run -p 7474:7474 -p 7687:7687 neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ========== Embedding ==========
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2                        # paragraph embeddings for Qdrant
EMBEDDING_DEVICE=cpu                                          # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32
QDRANT_VECTOR_SIZE=384                                        # must match embedding model output dim
IMAGERY_EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2  # imagery term clustering (50+ languages)

# ========== Summarization ==========
SUMMARY_MAX_CHAPTER_CHARS=8000                   # Max chapter chars sent to LLM
SUMMARY_TEMPERATURE=0.3                          # LLM temperature for summaries

# ========== Keyword Extraction (Phase 2b) ==========
KEYWORD_EXTRACTOR_TYPE=yake                      # yake | llm | tfidf | composite | none
YAKE_LANGUAGE=en                                 # language code for YAKE: en | zh | ja | ...
KEYWORD_MAX_PER_PARAGRAPH=10
KEYWORD_MAX_PER_CHAPTER=20
KEYWORD_MAX_PER_BOOK=30
KEYWORD_AGGREGATION_STRATEGY=weighted_sum        # sum | avg | max | weighted_sum
KEYWORD_COMPOSITE_WEIGHTS=yake:0.4,llm:0.6      # extractor:weight pairs for composite mode

# ========== LLM Thinking / Extended Reasoning ==========
# Enable extended thinking (reasoning) for supported models.
# WARNING: This consumes significantly more tokens and increases latency.
# Gemini 2.5: uses thinking_budget (token count, -1 = dynamic)
# Anthropic: uses extended thinking with budget_tokens
LLM_THINKING_ENABLED=false                          # Set to true to enable
LLM_THINKING_BUDGET=1024                            # Token budget when enabled

# ========== Chat Agent (Phase 4) ==========
CHAT_AGENT_MAX_ITERATIONS=10                     # Max ReAct loop iterations
CHAT_AGENT_TEMPERATURE=0.3                       # LLM temperature for chat agent

# ========== Cache ==========
CHAT_CACHE_TTL_SECONDS=300                       # ChatState tool cache: 5 min
ANALYSIS_CACHE_TTL_DAYS=7                        # Deep analysis cache: 7 days

# ========== Langfuse Tracing (optional) ==========
# Sign up at https://cloud.langfuse.com to get your API keys.
# Self-hosted: set LANGFUSE_BASE_URL to your own instance URL.
# When enabled, all LangChain / LangGraph calls and deep analysis spans are traced.
LANGFUSE_ENABLED=false                           # Set to true to enable
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here   # Langfuse public key
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here   # Langfuse secret key
LANGFUSE_BASE_URL=                               # Leave empty for cloud (https://cloud.langfuse.com)

# ========== Task Store ==========
TASK_STORE_BACKEND=memory                        # memory (dev) | sqlite (multi-worker)
TASK_STORE_DB_PATH=./data/tasks.db               # Only used when backend=sqlite
TASK_STORE_TTL_DAYS=30                           # Days to keep completed/failed tasks (0 = forever)

# ========== Application ==========
APP_ENV=development                              # development | production
LOG_LEVEL=INFO                                   # DEBUG | INFO | WARNING | ERROR
LOG_FILE=                                        # Optional log file path
APP_HOST=0.0.0.0
APP_PORT=8000
