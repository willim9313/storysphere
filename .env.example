# ============================================================
# StorySphere - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ========== LLM Providers ==========
GEMINI_API_KEY=your_gemini_api_key_here          # Primary LLM (required)
OPENAI_API_KEY=your_openai_api_key_here          # Fallback LLM (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here    # Fallback LLM (optional)

# ========== Database ==========
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./storysphere.db

# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/storysphere

# ========== Vector Database (Qdrant) ==========
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                                  # Leave empty for local Qdrant

# ========== Knowledge Graph (Neo4j - optional) ==========
# Requires Docker: docker run -p 7474:7474 -p 7687:7687 neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ========== Application ==========
APP_ENV=development                              # development | production
LOG_LEVEL=INFO                                   # DEBUG | INFO | WARNING | ERROR
APP_HOST=0.0.0.0
APP_PORT=8000

# ========== Cache ==========
CHAT_CACHE_TTL_SECONDS=300                       # ChatState tool cache: 5 min
ANALYSIS_CACHE_TTL_DAYS=7                        # Deep analysis cache: 7 days

# ========== Embedding ==========
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2           # sentence-transformers model id
EMBEDDING_DEVICE=cpu                             # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32
QDRANT_VECTOR_SIZE=384                           # must match embedding model output dim
